#!/usr/bin/env node
const puppeteer = require('puppeteer-core');
const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

process.env.PUPPETEER_SKIP_DOWNLOAD = 'true';
process.env.PUPPETEER_EXECUTABLE_PATH = '/usr/bin/chromium-browser';

const args = process.argv.slice(2);
const inputFile = args.find(a => a.startsWith('-i='))?.replace('-i=','') || args[0];
const outputFile = args.find(a => a.startsWith('-o='))?.replace('-o=','') || 'output.png';

console.log(`Converting ${inputFile} to ${outputFile}...`);
console.log('注意: Puppeteer 需要 Chromium 瀏覽器');
console.log('可用的替代方案:');
console.log('  - https://mermaid.live (線上)');
console.log('  - VSCode Mermaid Preview 擴充');
